# Cloudflare Turnstile secret key (keep this private)
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# Resend API key with email sending permissions
RESEND_API_KEY=your_resend_api_key

# Advisor email destination and from address
CONTACT_RECIPIENT=advisor@example.com
CONTACT_FROM_ADDRESS=no-reply@example.com

# Comma-separated allowed origins for CORS, e.g.:
# http://localhost:8000,https://www.example.com
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://www.example.com

# Comma-separated expected Turnstile hostnames for validation
EXPECTED_TURNSTILE_HOSTNAMES=127.0.0.1,localhost,example.com
